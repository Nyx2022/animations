			"content": "import Tree from \"./file-tree.svelte\";\r\nimport Folder from \"./folder.svelte\";\r\nimport File from \"./file.svelte\";\r\nimport CollapseButton from \"./collapse-button.svelte\";\r\nimport type { TreeViewElement } from \"./file-tree.svelte\";\r\n\r\nexport { Tree, Folder, File, CollapseButton };\r\nexport type { TreeViewElement };\r\n",
