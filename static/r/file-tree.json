{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "file-tree",
	"title": "File Tree",
	"type": "registry:block",
	"description": "An interactive file tree component with expandable folders, selectable files, and smooth animations.",
	"dependencies": [
		"motion-sv@^0.1.9"
